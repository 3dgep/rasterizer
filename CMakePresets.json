{
    "version": 7,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 27,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "vs18",
            "displayName": "Visual Studio 2026",
            "description": "Visual Studio 2026 Generator.",
            "generator": "Visual Studio 18 2026",
            "binaryDir": "${sourceDir}/out/build/${presetName}"
        },
        {
            "name": "vs17",
            "displayName": "Visual Studio 2022",
            "description": "Visual Studio 2022 Generator.",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/out/build/${presetName}"
        },
        {
            "name": "ninja",
            "displayName": "Ninja",
            "description": "Ninja generator (cross-platform)",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/out/build/${presetName}"
        }
    ],
    "buildPresets": [
        {
            "name": "vs18-debug",
            "displayName": "Visual Studio 2026 (Debug)",
            "configurePreset": "vs18",
            "configuration": "Debug"
        },
        {
            "name": "vs18-release",
            "displayName": "Visual Studio 2026 (Release)",
            "configurePreset": "vs18",
            "configuration": "Release"
        },
        {
            "name": "vs17-debug",
            "displayName": "Visual Studio 2022 (Debug)",
            "configurePreset": "vs17",
            "configuration": "Debug"
        },
        {
            "name": "vs17-release",
            "displayName": "Visual Studio 2022 (Release)",
            "configurePreset": "vs17",
            "configuration": "Release"
        },
        {
            "name": "ninja-debug",
            "displayName": "Ninja (Debug)",
            "configurePreset": "ninja",
            "configuration": "Debug"
        },
        {
            "name": "ninja-release",
            "displayName": "Ninja (Release)",
            "configurePreset": "ninja",
            "configuration": "Release"
        }
    ],
    "packagePresets": [
        {
            "name": "vs18-PixelAdventure",
            "displayName": "15-PixelAdventure (VS 2026)",
            "configurePreset": "vs18",
            "configurations": ["Release"],
            "generators": ["ZIP"],
            "variables": {
                "CPACK_COMPONENTS_ALL": "15-PixelAdventure"
            }
        },
        {
            "name": "vs18-Arkanoid",
            "displayName": "16-Arkanoid (VS 2026)",
            "configurePreset": "vs18",
            "configurations": ["Release"],
            "generators": ["ZIP"],
            "variables": {
                "CPACK_COMPONENTS_ALL": "16-Arkanoid"
            }
        },
        {
            "name": "vs17-PixelAdventure",
            "displayName": "15-PixelAdventure (VS 2022)",
            "configurePreset": "vs17",
            "configurations": ["Release"],
            "generators": ["ZIP"],
            "variables": {
                "CPACK_COMPONENTS_ALL": "15-PixelAdventure"
            }
        },
        {
            "name": "vs17-Arkanoid",
            "displayName": "16-Arkanoid (VS 2022)",
            "configurePreset": "vs17",
            "configurations": ["Release"],
            "generators": ["ZIP"],
            "variables": {
                "CPACK_COMPONENTS_ALL": "16-Arkanoid"
            }
        }
    ],
    "workflowPresets": [
        {
            "name": "vs18-PixelAdventure",
            "displayName": "15-PixelAdventure (VS 2026)",
            "steps": [
                {
                    "type": "configure",
                    "name": "vs18"
                },
                {
                    "type": "build",
                    "name": "vs18-release"
                },
                {
                    "type": "package",
                    "name": "vs18-PixelAdventure"
                }
            ]
        },
        {
            "name": "vs17-PixelAdventure",
            "displayName": "15-PixelAdventure (VS 2022)",
            "steps": [
                {
                    "type": "configure",
                    "name": "vs17"
                },
                {
                    "type": "build",
                    "name": "vs17-release"
                },
                {
                    "type": "package",
                    "name": "vs17-PixelAdventure"
                }
            ]
        }
    ]
}
